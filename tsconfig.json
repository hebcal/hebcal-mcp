{
  "compilerOptions": {
    "target": "es2023",
    "module": "ES2022",
    "lib": ["es2023", "dom", "esnext.temporal", "esnext.intl", "esnext.date"],
    "types": ["node"],
    "outDir": "./build",
    "rootDir": "./src",
    "sourceMap": false,
    "skipLibCheck": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "paths": {
      "*": ["./types/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules"]
}
